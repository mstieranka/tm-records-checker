{
  "name": "tm-records-checker",
  "version": "2.0.0",
  "license": "ISC",
  "author": "Matej Stieranka <matej@stieranka.eu>",
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production bunx --bun react-router build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run migrate.ts",
    "db:migrate-data": "bun run migrate-data.ts",
    "dev": "bunx --bun react-router dev",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "start": "bunx --bun cross-env NODE_ENV=production react-router-serve ./build/server/index.js",
    "start:cron": "cross-env NODE_ENV=production bun cron.ts",
    "start:prod": "bun db:migrate && concurrently \"bun run start\" \"bun run start:cron\"",
    "validate": "bun fmt:check && bun lint && bun typecheck",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@conform-to/react": "^1.19.2",
    "@conform-to/zod": "^1.19.2",
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/inter": "5.2.8",
    "@react-router/fs-routes": "7.15.0",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "@tabler/icons-react": "3.44.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "drizzle-orm": "0.45.2",
    "isbot": "5.1.40",
    "jose": "6.2.3",
    "next-themes": "0.4.6",
    "node-cron": "4.2.1",
    "postgres": "3.4.9",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0",
    "remix-auth": "4.2.0",
    "remix-auth-github": "3.0.2",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bun-types": "1.3.13",
    "drizzle-kit": "0.31.10",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.11"
  }
}
