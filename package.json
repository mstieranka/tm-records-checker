{
  "name": "tm-records-checker",
  "version": "2.0.0",
  "license": "ISC",
  "author": "Matej Stieranka <matej@stieranka.eu>",
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production bunx --bun react-router build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run migrate.ts",
    "dev": "bunx --bun react-router dev",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "start": "bunx --bun cross-env NODE_ENV=production react-router-serve ./build/server/index.js",
    "start:cron": "cross-env NODE_ENV=production bun cron.ts",
    "start:prod": "bun db:migrate && concurrently \"bun run start\" \"bun run start:cron\"",
    "validate": "bun fmt:check && bun lint && bun typecheck",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@picocss/pico": "2.1.1",
    "@react-router/fs-routes": "7.15.0",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "drizzle-orm": "0.31.4",
    "isbot": "4.4.0",
    "jose": "4.15.9",
    "node-cron": "3.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.15.0",
    "remix-auth": "4.2.0",
    "remix-auth-github": "3.0.2"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.0",
    "@types/node-cron": "3.0.11",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "bun-types": "1.3.13",
    "drizzle-kit": "0.22.8",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "typescript": "5.9.3",
    "vite": "8.0.11"
  }
}
